{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "WebCodeCli (HTTP)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/WebCodeCli/bin/Debug/net10.0/WebCodeCli.exe",
            "args": [],
            "cwd": "${workspaceFolder}/WebCodeCli",
            "stopAtEntry": false,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            },
            "sourceFileMap": {
                "/Views": "${workspaceFolder}/WebCodeCli/Views"
            }
        },
        {
            "name": "WebCodeCli (HTTPS)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/WebCodeCli/bin/Debug/net10.0/WebCodeCli.exe",
            "args": [],
            "cwd": "${workspaceFolder}/WebCodeCli",
            "stopAtEntry": false,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "ASPNETCORE_URLS": "https://localhost:7044;http://localhost:5254"
            },
            "sourceFileMap": {
                "/Views": "${workspaceFolder}/WebCodeCli/Views"
            }
        },
        {
            "name": ".NET Core Attach",
            "type": "coreclr",
            "request": "attach"
        }
    ]
}
