@using WebCodeCli.Domain.Domain.Model
@inject IJSRuntime JSRuntime
@implements IDisposable

<div id="chat-messages-container" class="flex-1 overflow-y-auto overflow-x-hidden space-y-2 sm:space-y-3 mb-3 sm:mb-4 lg:mb-5">
    @foreach (var message in Messages)
    {
        var messageId = $"message-{message.Id}";
        <div class="@(message.Role == "user" ? "bg-white border-l-4 border-gray-300 shadow-sm" : "bg-gray-50 border-l-4 border-blue-500 shadow-sm") rounded-lg sm:rounded-xl p-3 sm:p-4 hover:shadow-md transition-all border border-gray-100 overflow-hidden">
            <div class="flex justify-between items-center mb-2 sm:mb-3">
                <div class="flex items-center gap-1.5 sm:gap-2">
                    @if (message.Role == "user")
                    {
                        <div class="w-7 h-7 sm:w-8 sm:h-8 bg-gradient-to-br from-gray-600 to-gray-700 rounded-full flex items-center justify-center shadow-sm">
                            <svg class="w-4 h-4 sm:w-4.5 sm:h-4.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                            </svg>
                        </div>
                        <span class="font-bold text-sm sm:text-base text-gray-700">@UserLabel</span>
                    }
                    else
                    {
                        <div class="w-7 h-7 sm:w-8 sm:h-8 bg-gradient-to-br from-blue-500 to-blue-600 rounded-full flex items-center justify-center shadow-md">
                            <svg class="w-4 h-4 sm:w-4.5 sm:h-4.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
                            </svg>
                        </div>
                        <span class="font-bold text-sm sm:text-base text-blue-700">@AssistantLabel</span>
                    }
                </div>
                <div class="flex items-center gap-1 sm:gap-2">
                    <span class="text-[10px] sm:text-xs text-gray-500 font-medium">@message.CreatedAt.ToString("HH:mm:ss")</span>
                    <!-- Copy Button -->
                    <button @onclick="@(() => CopyMessageContent(message))" 
                            class="p-1 sm:p-1.5 rounded hover:bg-gray-200 transition-colors group relative"
                            title="@CopyMessageLabel"
                            aria-label="@CopyMessageLabel">
                        @if (_copiedMessageId == message.Id)
                        {
                            <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                            </svg>
                        }
                        else
                        {
                            <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4 text-gray-500 group-hover:text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
                            </svg>
                        }
                    </button>
                    <!-- Fullscreen Button -->
                    <button @onclick="@(() => ShowFullscreenMessage(message))" 
                            class="p-1 sm:p-1.5 rounded hover:bg-gray-200 transition-colors group"
                            title="@FullscreenLabel"
                            aria-label="@FullscreenLabel">
                        <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4 text-gray-500 group-hover:text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4"></path>
                        </svg>
                    </button>
                </div>
            </div>
            <div class="text-xs sm:text-sm">
                @if (message.HasError)
                {
                    <div class="bg-red-50 border-l-4 border-red-500 text-red-700 px-3 sm:px-4 py-2 sm:py-3 rounded-lg shadow-sm" role="alert">
                        <div class="flex items-start gap-2">
                            <svg class="w-5 h-5 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                            </svg>
                            <span class="block">@message.ErrorMessage</span>
                        </div>
                    </div>
                }
                else
                {
                    var content = message.Content ?? string.Empty;
                    if (IsJsonlContent(content))
                    {
                        @((MarkupString)RenderJsonlContent(content))
                    }
                    else
                    {
                        <div class="max-h-60 sm:max-h-96 overflow-y-auto text-gray-700 leading-relaxed markdown-preview" style="word-break: break-all;">@RenderMarkdown(content)</div>
                    }
                }
            </div>
            @if (message.Attachments.Any())
            {
                <div class="mt-3 flex flex-wrap gap-2">
                    @foreach (var attachment in message.Attachments)
                    {
                        <span class="inline-flex max-w-full items-center gap-1.5 rounded-full border border-slate-200 bg-slate-100 px-3 py-1 text-[11px] sm:text-xs text-slate-700"
                              title="@GetAttachmentTitle(attachment)">
                            <svg class="h-3.5 w-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13"></path>
                            </svg>
                            <span class="truncate max-w-[220px]">@attachment.DisplayName</span>
                        </span>
                    }
                </div>
            }
            @if (ShouldShowSuperpowersQuickActions(message))
            {
                <div class="mt-3 rounded-lg border border-blue-100 bg-blue-50/60 p-3">
                    <p class="mb-2 text-xs sm:text-sm text-blue-900">@SuperpowersInstructionText</p>
                    <div class="flex flex-col items-stretch gap-2">
                        @if (ShowSuperpowersPlanActions)
                        {
                            <div class="flex flex-wrap gap-2 sm:justify-end">
                                <button @onclick="@(() => OnExecuteSuperpowersPlan.InvokeAsync(message))"
                                        disabled="@SuperpowersQuickActionDisabled"
                                        class="inline-flex items-center justify-center gap-1.5 rounded-lg border border-blue-200 px-3 py-1.5 text-xs sm:text-sm font-medium transition-colors @(SuperpowersQuickActionDisabled ? "cursor-not-allowed bg-gray-100 text-gray-400 border-gray-200" : "bg-white text-blue-700 hover:bg-blue-100")">
                                    <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
                                    </svg>
                                    <span>@ExecutePlanText</span>
                                </button>
                                <button @onclick="@(() => OnExecuteSuperpowersSubagentPlan.InvokeAsync(message))"
                                        disabled="@SuperpowersQuickActionDisabled"
                                        class="inline-flex items-center justify-center gap-1.5 rounded-lg border border-blue-200 px-3 py-1.5 text-xs sm:text-sm font-medium transition-colors @(SuperpowersQuickActionDisabled ? "cursor-not-allowed bg-gray-100 text-gray-400 border-gray-200" : "bg-blue-600 text-white hover:bg-blue-700")">
                                    <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
                                    </svg>
                                    <span>@ExecuteSubagentPlanText</span>
                                </button>
                                <button @onclick="@(() => OnExecuteSuperpowersCompleteWorktree.InvokeAsync(message))"
                                        disabled="@SuperpowersQuickActionDisabled"
                                        class="inline-flex items-center justify-center gap-1.5 rounded-lg border border-blue-200 px-3 py-1.5 text-xs sm:text-sm font-medium transition-colors @(SuperpowersQuickActionDisabled ? "cursor-not-allowed bg-gray-100 text-gray-400 border-gray-200" : "bg-white text-blue-700 hover:bg-blue-100")">
                                    <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
                                    </svg>
                                    <span>@CompleteWorktreeText</span>
                                </button>
                            </div>
                        }
                        <input @bind:get="SuperpowersQuickInput"
                               @bind:set="HandleSuperpowersQuickInputChangedAsync"
                               @bind:event="oninput"
                               @onkeydown="@(args => HandleSuperpowersQuickInputKeyDown(message, args))"
                               disabled="@SuperpowersQuickActionDisabled"
                               class="w-full rounded-lg border border-blue-200 bg-white px-3 py-2 text-xs sm:text-sm text-gray-700 shadow-sm outline-none transition focus:border-blue-400 focus:ring-2 focus:ring-blue-100 disabled:cursor-not-allowed disabled:bg-gray-100 disabled:text-gray-400"
                               placeholder="@SuperpowersQuickInputPlaceholder" />
                        @if (!string.IsNullOrWhiteSpace(SuperpowersQuickActionStatusMessage) || ShowSuperpowersRetryAction)
                        {
                            <div class="flex flex-wrap items-center justify-between gap-2 rounded-lg border border-blue-100 bg-white/70 px-3 py-2 text-xs text-blue-900">
                                @if (!string.IsNullOrWhiteSpace(SuperpowersQuickActionStatusMessage))
                                {
                                    <span>@SuperpowersQuickActionStatusMessage</span>
                                }
                                @if (ShowSuperpowersRetryAction)
                                {
                                    <button @onclick="@(() => OnRetrySuperpowersCapability.InvokeAsync(message))"
                                            disabled="@SuperpowersRetryActionDisabled"
                                            class="inline-flex items-center justify-center rounded-md border border-blue-200 px-2.5 py-1 font-medium transition-colors @(SuperpowersRetryActionDisabled ? "cursor-not-allowed bg-gray-100 text-gray-400 border-gray-200" : "text-blue-700 hover:bg-blue-100")"
                                            type="button">
                                        @SuperpowersRetryActionText
                                    </button>
                                }
                            </div>
                        }
                    </div>
                </div>
            }
            @if (ShouldShowGoalQuickActions(message))
            {
                <div class="mt-3 rounded-lg border border-emerald-100 bg-emerald-50/60 p-3">
                    <p class="mb-2 text-xs sm:text-sm text-emerald-900">@GoalInstructionText</p>
                    <div class="flex flex-col items-stretch gap-2">
                        <input @bind:get="GoalQuickInput"
                               @bind:set="HandleGoalQuickInputChangedAsync"
                               @bind:event="oninput"
                               @onkeydown="@(args => HandleGoalQuickInputKeyDown(message, args))"
                               disabled="@GoalQuickActionDisabled"
                               class="w-full rounded-lg border border-emerald-200 bg-white px-3 py-2 text-xs sm:text-sm text-gray-700 shadow-sm outline-none transition focus:border-emerald-400 focus:ring-2 focus:ring-emerald-100 disabled:cursor-not-allowed disabled:bg-gray-100 disabled:text-gray-400"
                               placeholder="@GoalQuickInputPlaceholder" />
                        <button @onclick="@(() => OnSubmitGoalQuickInput.InvokeAsync(message))"
                                disabled="@GoalQuickActionDisabled"
                                type="button"
                                class="inline-flex w-full items-center justify-center gap-1.5 rounded-lg border border-emerald-200 px-3 py-1.5 text-xs sm:text-sm font-medium transition-colors @(GoalQuickActionDisabled ? "cursor-not-allowed bg-gray-100 text-gray-400 border-gray-200" : "bg-emerald-600 text-white hover:bg-emerald-700")">
                            <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
                            </svg>
                            <span>@GoalSubmitActionText</span>
                        </button>
                        <div class="grid grid-cols-2 gap-2">
                            <button @onclick="@(() => OnGoalStatusAction.InvokeAsync(message))"
                                    disabled="@GoalQuickActionDisabled"
                                    type="button"
                                    class="inline-flex w-full items-center justify-center rounded-lg border border-emerald-200 px-3 py-1.5 text-xs sm:text-sm font-medium transition-colors @(GoalQuickActionDisabled ? "cursor-not-allowed bg-gray-100 text-gray-400 border-gray-200" : "bg-white text-emerald-700 hover:bg-emerald-100")">
                                @GoalStatusActionText
                            </button>
                            <button @onclick="@(() => OnGoalPauseAction.InvokeAsync(message))"
                                    disabled="@GoalPauseActionDisabled"
                                    type="button"
                                    class="inline-flex w-full items-center justify-center rounded-lg border border-emerald-200 px-3 py-1.5 text-xs sm:text-sm font-medium transition-colors @(GoalPauseActionDisabled ? "cursor-not-allowed bg-gray-100 text-gray-400 border-gray-200" : "bg-white text-emerald-700 hover:bg-emerald-100")">
                                @GoalPauseActionText
                            </button>
                            <button @onclick="@(() => OnGoalClearAction.InvokeAsync(message))"
                                    disabled="@GoalQuickActionDisabled"
                                    type="button"
                                    class="inline-flex w-full items-center justify-center rounded-lg border border-emerald-200 px-3 py-1.5 text-xs sm:text-sm font-medium transition-colors @(GoalQuickActionDisabled ? "cursor-not-allowed bg-gray-100 text-gray-400 border-gray-200" : "bg-white text-emerald-700 hover:bg-emerald-100")">
                                @GoalClearActionText
                            </button>
                            <button @onclick="@(() => OnGoalResumeAction.InvokeAsync(message))"
                                    disabled="@GoalQuickActionDisabled"
                                    type="button"
                                    class="inline-flex w-full items-center justify-center rounded-lg border border-emerald-200 px-3 py-1.5 text-xs sm:text-sm font-medium transition-colors @(GoalQuickActionDisabled ? "cursor-not-allowed bg-gray-100 text-gray-400 border-gray-200" : "bg-white text-emerald-700 hover:bg-emerald-100")">
                                @GoalResumeActionText
                            </button>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(GoalQuickActionStatusMessage) || ShowGoalRetryAction)
                        {
                            <div class="flex flex-wrap items-center justify-between gap-2 rounded-lg border border-emerald-100 bg-white/70 px-3 py-2 text-xs text-emerald-900">
                                @if (!string.IsNullOrWhiteSpace(GoalQuickActionStatusMessage))
                                {
                                    <span>@GoalQuickActionStatusMessage</span>
                                }
                                @if (ShowGoalRetryAction)
                                {
                                    <button @onclick="@(() => OnRetryGoalCapability.InvokeAsync(message))"
                                            disabled="@GoalRetryActionDisabled"
                                            class="inline-flex items-center justify-center rounded-md border border-emerald-200 px-2.5 py-1 font-medium transition-colors @(GoalRetryActionDisabled ? "cursor-not-allowed bg-gray-100 text-gray-400 border-gray-200" : "text-emerald-700 hover:bg-emerald-100")"
                                            type="button">
                                        @GoalRetryActionText
                                    </button>
                                }
                            </div>
                        }
                        @if (ShowSuperpowersPlanActions)
                        {
                            <div class="grid grid-cols-2 gap-2">
                                @if (ShowStopSuperpowersAction)
                                {
                                    <button @onclick="@(() => OnStopSuperpowersAction.InvokeAsync(message))"
                                            disabled="@StopSuperpowersActionDisabled"
                                            class="inline-flex w-full items-center justify-center gap-1.5 rounded-lg border border-red-200 px-3 py-1.5 text-xs sm:text-sm font-medium transition-colors @(StopSuperpowersActionDisabled ? "cursor-not-allowed bg-gray-100 text-gray-400 border-gray-200" : "bg-white text-red-700 hover:bg-red-50")">
                                        <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4" fill="currentColor" viewBox="0 0 24 24">
                                            <path d="M7 7h10v10H7z"></path>
                                        </svg>
                                        <span>@StopSuperpowersActionText</span>
                                    </button>
                                }
                                <button @onclick="@(() => OnContinueSuperpowersAction.InvokeAsync(message))"
                                        disabled="@ContinueSuperpowersActionDisabled"
                                        class="inline-flex w-full items-center justify-center gap-1.5 rounded-lg border border-blue-200 px-3 py-1.5 text-xs sm:text-sm font-medium transition-colors @(ShowStopSuperpowersAction ? string.Empty : "col-span-2") @(ContinueSuperpowersActionDisabled ? "cursor-not-allowed bg-gray-100 text-gray-400 border-gray-200" : "bg-white text-blue-700 hover:bg-blue-100")">
                                    <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l-7 7 7 7"></path>
                                    </svg>
                                    <span>@ContinueActionText</span>
                                </button>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }

    @if (IsLoading)
    {
        <div class="bg-gray-50 border-l-4 border-blue-500 rounded-lg sm:rounded-xl p-3 sm:p-4 shadow-md animate-pulse overflow-hidden">
            <div class="flex justify-between items-center rounded-lg bg-white/60 px-3 py-2 sm:px-4 sm:py-3 border-b-2 border-red-300">
                <div class="flex items-center gap-2">
                    <div class="w-7 h-7 sm:w-8 sm:h-8 bg-gradient-to-br from-blue-500 to-blue-600 rounded-full flex items-center justify-center shadow-md">
                        <svg class="w-4 h-4 sm:w-4.5 sm:h-4.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
                        </svg>
                    </div>
                    <span class="font-bold text-sm sm:text-base text-blue-700">@AssistantLabel</span>
                </div>
                <div class="flex items-center gap-1.5 sm:gap-2">
                    <span class="text-[10px] sm:text-xs text-blue-600 font-semibold">@ThinkingText</span>
                    <div class="animate-spin h-3 w-3 sm:h-4 sm:w-4 border-2 border-blue-600 rounded-full border-t-transparent"></div>
                </div>
            </div>
            <div class="mt-3 rounded-lg bg-white/70 px-3 py-3 sm:px-4">
                <div class="text-xs sm:text-sm max-h-60 sm:max-h-96 overflow-y-auto overflow-x-hidden text-gray-700 leading-relaxed break-words">@RenderMarkdown(CurrentAssistantMessage)</div>
            </div>
            @if (ShouldShowStreamingSuperpowersQuickActions())
            {
                <div class="mt-3 border-t-2 border-red-300 pt-3">
                    <div class="rounded-lg border border-blue-100 bg-blue-50/60 p-3">
                        <p class="mb-2 text-xs sm:text-sm text-blue-900">@SuperpowersInstructionText</p>
                        <div class="flex flex-col items-stretch gap-2">
                            @if (ShowSuperpowersPlanActions)
                            {
                                <div class="flex flex-wrap gap-2 sm:justify-end">
                                    <button disabled="true"
                                            class="inline-flex items-center justify-center gap-1.5 rounded-lg border border-gray-200 bg-gray-100 px-3 py-1.5 text-xs sm:text-sm font-medium text-gray-400">
                                        <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
                                        </svg>
                                        <span>@ExecutePlanText</span>
                                    </button>
                                    <button disabled="true"
                                            class="inline-flex items-center justify-center gap-1.5 rounded-lg border border-gray-200 bg-gray-100 px-3 py-1.5 text-xs sm:text-sm font-medium text-gray-400">
                                        <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
                                        </svg>
                                        <span>@ExecuteSubagentPlanText</span>
                                    </button>
                                    <button disabled="true"
                                            class="inline-flex items-center justify-center gap-1.5 rounded-lg border border-gray-200 bg-gray-100 px-3 py-1.5 text-xs sm:text-sm font-medium text-gray-400">
                                        <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
                                        </svg>
                                        <span>@CompleteWorktreeText</span>
                                    </button>
                                </div>
                            }
                            <input value="@SuperpowersQuickInput"
                                   disabled="true"
                                   class="w-full rounded-lg border border-blue-200 bg-gray-100 px-3 py-2 text-xs sm:text-sm text-gray-400 shadow-sm outline-none disabled:cursor-not-allowed"
                                   placeholder="@SuperpowersQuickInputPlaceholder" />
                        </div>
                    </div>
                </div>
            }
            @if (ShouldShowStreamingGoalQuickActions())
            {
                <div class="mt-3 border-t-2 border-red-300 pt-3">
                    <div class="rounded-lg border border-emerald-100 bg-emerald-50/60 p-3">
                        <p class="mb-2 text-xs sm:text-sm text-emerald-900">@GoalInstructionText</p>
                        <div class="flex flex-col items-stretch gap-2">
                            <input value="@GoalQuickInput"
                                   disabled="true"
                                   class="w-full rounded-lg border border-emerald-200 bg-gray-100 px-3 py-2 text-xs sm:text-sm text-gray-400 shadow-sm outline-none disabled:cursor-not-allowed"
                                   placeholder="@GoalQuickInputPlaceholder" />
                            <button disabled="true"
                                    class="inline-flex w-full items-center justify-center gap-1.5 rounded-lg border border-gray-200 bg-gray-100 px-3 py-1.5 text-xs sm:text-sm font-medium text-gray-400">
                                <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
                                </svg>
                                <span>@GoalSubmitActionText</span>
                            </button>
                            <div class="grid grid-cols-2 gap-2">
                                <button disabled="true"
                                        class="inline-flex w-full items-center justify-center rounded-lg border border-gray-200 bg-gray-100 px-3 py-1.5 text-xs sm:text-sm font-medium text-gray-400">
                                    @GoalStatusActionText
                                </button>
                                <button disabled="true"
                                        class="inline-flex w-full items-center justify-center rounded-lg border border-gray-200 bg-gray-100 px-3 py-1.5 text-xs sm:text-sm font-medium text-gray-400">
                                    @GoalPauseActionText
                                </button>
                                <button disabled="true"
                                        class="inline-flex w-full items-center justify-center rounded-lg border border-gray-200 bg-gray-100 px-3 py-1.5 text-xs sm:text-sm font-medium text-gray-400">
                                    @GoalClearActionText
                                </button>
                                <button disabled="true"
                                        class="inline-flex w-full items-center justify-center rounded-lg border border-gray-200 bg-gray-100 px-3 py-1.5 text-xs sm:text-sm font-medium text-gray-400">
                                    @GoalResumeActionText
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
            @if (ShowSuperpowersPlanActions)
            {
                <div class="grid grid-cols-2 gap-2">
                    @if (ShowStopSuperpowersAction)
                    {
                        <button disabled="true"
                                class="inline-flex w-full items-center justify-center gap-1.5 rounded-lg border border-red-200 bg-gray-100 px-3 py-1.5 text-xs sm:text-sm font-medium text-gray-400">
                            <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4" fill="currentColor" viewBox="0 0 24 24">
                                <path d="M7 7h10v10H7z"></path>
                            </svg>
                            <span>@StopSuperpowersActionText</span>
                        </button>
                    }
                    <button disabled="true"
                            class="inline-flex w-full items-center justify-center gap-1.5 rounded-lg border border-gray-200 bg-gray-100 px-3 py-1.5 text-xs sm:text-sm font-medium text-gray-400 @(ShowStopSuperpowersAction ? string.Empty : "col-span-2")">
                        <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l-7 7 7 7"></path>
                        </svg>
                        <span>@ContinueActionText</span>
                    </button>
                </div>
            }
        </div>
    }
</div>

<!-- Fullscreen Modal -->
@if (_fullscreenMessage != null)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center bg-black bg-opacity-75" 
         @onclick="CloseFullscreen"
         @onkeydown="HandleModalKeyDown"
         role="dialog"
         aria-modal="true"
         aria-labelledby="modal-title"
         tabindex="-1">
        <div class="bg-white rounded-lg shadow-2xl w-11/12 h-5/6 max-w-6xl flex flex-col" @onclick:stopPropagation="true">
            <!-- Modal Header -->
            <div class="flex justify-between items-center p-4 border-b border-gray-200">
                <div class="flex items-center gap-2" id="modal-title">
                    @if (_fullscreenMessage.Role == "user")
                    {
                        <div class="w-8 h-8 bg-gradient-to-br from-gray-600 to-gray-700 rounded-full flex items-center justify-center shadow-sm">
                            <svg class="w-4.5 h-4.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                            </svg>
                        </div>
                        <span class="font-bold text-base text-gray-700">@UserLabel</span>
                    }
                    else
                    {
                        <div class="w-8 h-8 bg-gradient-to-br from-blue-500 to-blue-600 rounded-full flex items-center justify-center shadow-md">
                            <svg class="w-4.5 h-4.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
                            </svg>
                        </div>
                        <span class="font-bold text-base text-blue-700">@AssistantLabel</span>
                    }
                    <span class="text-xs text-gray-500 font-medium ml-2">@_fullscreenMessage.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss")</span>
                </div>
                <div class="flex items-center gap-2">
                    <!-- Copy Button in Modal -->
                    <button @onclick="@(() => CopyMessageContent(_fullscreenMessage))" 
                            @onclick:stopPropagation="true"
                            class="px-3 py-1.5 rounded-lg border border-gray-300 hover:bg-gray-100 transition-colors flex items-center gap-2"
                            title="@CopyMessageLabel"
                            aria-label="@CopyMessageLabel">
                        @if (_copiedMessageId == _fullscreenMessage.Id)
                        {
                            <svg class="w-4 h-4 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                            </svg>
                            <span class="text-sm text-green-600">@CopiedLabel</span>
                        }
                        else
                        {
                            <svg class="w-4 h-4 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
                            </svg>
                            <span class="text-sm text-gray-600">@CopyMessageLabel</span>
                        }
                    </button>
                    <!-- Close Button -->
                    <button @onclick="CloseFullscreen" 
                            @onclick:stopPropagation="true"
                            class="p-2 rounded-lg hover:bg-gray-100 transition-colors"
                            title="@ExitFullscreenLabel"
                            aria-label="@ExitFullscreenLabel">
                        <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                        </svg>
                    </button>
                </div>
            </div>
            <!-- Modal Content -->
            <div class="flex-1 overflow-y-auto p-6">
                @if (_fullscreenMessage.HasError)
                {
                    <div class="bg-red-50 border-l-4 border-red-500 text-red-700 px-4 py-3 rounded-lg shadow-sm" role="alert">
                        <div class="flex items-start gap-2">
                            <svg class="w-5 h-5 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                            </svg>
                            <span class="block text-base">@_fullscreenMessage.ErrorMessage</span>
                        </div>
                    </div>
                }
                else
                {
                    var content = _fullscreenMessage.Content ?? string.Empty;
                    if (IsJsonlContent(content))
                    {
                        @((MarkupString)RenderJsonlContent(content))
                    }
                    else
                    {
                        <div class="text-gray-700 leading-relaxed markdown-preview text-base" style="word-break: break-all;">@RenderMarkdown(content)</div>
                    }
                }
                @if (_fullscreenMessage.Attachments.Any())
                {
                    <div class="mt-4 flex flex-wrap gap-2">
                        @foreach (var attachment in _fullscreenMessage.Attachments)
                        {
                            <span class="inline-flex max-w-full items-center gap-1.5 rounded-full border border-slate-200 bg-slate-100 px-3 py-1.5 text-sm text-slate-700"
                                  title="@GetAttachmentTitle(attachment)">
                                <svg class="h-4 w-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13"></path>
                                </svg>
                                <span class="truncate max-w-[320px]">@attachment.DisplayName</span>
                            </span>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public IReadOnlyList<ChatMessage> Messages { get; set; } = Array.Empty<ChatMessage>();
    [Parameter] public bool IsLoading { get; set; }
    [Parameter] public string CurrentAssistantMessage { get; set; } = string.Empty;

    [Parameter] public string UserLabel { get; set; } = string.Empty;
    [Parameter] public string AssistantLabel { get; set; } = string.Empty;
    [Parameter] public string ThinkingText { get; set; } = string.Empty;
    [Parameter] public string CopyMessageLabel { get; set; } = string.Empty;
    [Parameter] public string CopiedLabel { get; set; } = string.Empty;
    [Parameter] public string FullscreenLabel { get; set; } = string.Empty;
    [Parameter] public string ExitFullscreenLabel { get; set; } = string.Empty;

    [Parameter] public Func<string, bool> IsJsonlContent { get; set; } = _ => false;
    [Parameter] public Func<string, string> RenderJsonlContent { get; set; } = _ => string.Empty;
    [Parameter] public Func<string, MarkupString> RenderMarkdown { get; set; } = _ => new MarkupString(string.Empty);
    [Parameter] public string? SuperpowersQuickActionMessageId { get; set; }
    [Parameter] public bool SuperpowersQuickActionDisabled { get; set; }
    [Parameter] public bool ShowSuperpowersPlanActions { get; set; }
    [Parameter] public string SuperpowersInstructionText { get; set; } = SuperpowersQuickActionDefaults.InstructionText;
    [Parameter] public string SuperpowersQuickInput { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> SuperpowersQuickInputChanged { get; set; }
    [Parameter] public string SuperpowersQuickInputPlaceholder { get; set; } = SuperpowersQuickActionDefaults.QuickInputPlaceholder;
    [Parameter] public string ContinueActionText { get; set; } = SuperpowersQuickActionDefaults.ContinueButtonText;
    [Parameter] public bool ContinueSuperpowersActionDisabled { get; set; }
    [Parameter] public string ExecutePlanText { get; set; } = SuperpowersQuickActionDefaults.ExecutePlanButtonText;
    [Parameter] public string ExecuteSubagentPlanText { get; set; } = SuperpowersQuickActionDefaults.ExecuteSubagentPlanButtonText;
    [Parameter] public string CompleteWorktreeText { get; set; } = SuperpowersQuickActionDefaults.CompleteWorktreeButtonText;
    [Parameter] public bool ShowStopSuperpowersAction { get; set; }
    [Parameter] public bool StopSuperpowersActionDisabled { get; set; }
    [Parameter] public string StopSuperpowersActionText { get; set; } = "停止";
    [Parameter] public string? SuperpowersQuickActionStatusMessage { get; set; }
    [Parameter] public bool ShowSuperpowersRetryAction { get; set; }
    [Parameter] public bool SuperpowersRetryActionDisabled { get; set; }
    [Parameter] public string SuperpowersRetryActionText { get; set; } = SuperpowersQuickActionDefaults.CapabilityRetryButtonText;
    [Parameter] public EventCallback<ChatMessage> OnSubmitSuperpowersQuickInput { get; set; }
    [Parameter] public EventCallback<ChatMessage> OnContinueSuperpowersAction { get; set; }
    [Parameter] public EventCallback<ChatMessage> OnExecuteSuperpowersPlan { get; set; }
    [Parameter] public EventCallback<ChatMessage> OnExecuteSuperpowersSubagentPlan { get; set; }
    [Parameter] public EventCallback<ChatMessage> OnExecuteSuperpowersCompleteWorktree { get; set; }
    [Parameter] public EventCallback<ChatMessage> OnStopSuperpowersAction { get; set; }
    [Parameter] public EventCallback<ChatMessage> OnRetrySuperpowersCapability { get; set; }
    [Parameter] public string? GoalQuickActionMessageId { get; set; }
    [Parameter] public bool EnableGoalQuickActions { get; set; }
    [Parameter] public bool GoalQuickActionDisabled { get; set; }
    [Parameter] public bool GoalPauseActionDisabled { get; set; }
    [Parameter] public string GoalInstructionText { get; set; } = GoalQuickActionDefaults.InstructionText;
    [Parameter] public string GoalQuickInput { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> GoalQuickInputChanged { get; set; }
    [Parameter] public string GoalQuickInputPlaceholder { get; set; } = GoalQuickActionDefaults.QuickInputPlaceholder;
    [Parameter] public string GoalSubmitActionText { get; set; } = GoalQuickActionDefaults.QuickSubmitButtonText;
    [Parameter] public string GoalStatusActionText { get; set; } = GoalQuickActionDefaults.StatusButtonText;
    [Parameter] public string GoalPauseActionText { get; set; } = GoalQuickActionDefaults.PauseButtonText;
    [Parameter] public string GoalClearActionText { get; set; } = GoalQuickActionDefaults.ClearButtonText;
    [Parameter] public string GoalResumeActionText { get; set; } = GoalQuickActionDefaults.ResumeButtonText;
    [Parameter] public string? GoalQuickActionStatusMessage { get; set; }
    [Parameter] public bool ShowGoalRetryAction { get; set; }
    [Parameter] public bool GoalRetryActionDisabled { get; set; }
    [Parameter] public string GoalRetryActionText { get; set; } = GoalQuickActionDefaults.CapabilityRetryButtonText;
    [Parameter] public EventCallback<ChatMessage> OnSubmitGoalQuickInput { get; set; }
    [Parameter] public EventCallback<ChatMessage> OnGoalStatusAction { get; set; }
    [Parameter] public EventCallback<ChatMessage> OnGoalPauseAction { get; set; }
    [Parameter] public EventCallback<ChatMessage> OnGoalClearAction { get; set; }
    [Parameter] public EventCallback<ChatMessage> OnGoalResumeAction { get; set; }
    [Parameter] public EventCallback<ChatMessage> OnRetryGoalCapability { get; set; }

    private string? _copiedMessageId = null;
    private ChatMessage? _fullscreenMessage = null;
    private CancellationTokenSource? _copiedResetCts = null;

    private static string GetAttachmentTitle(MessageAttachment attachment)
    {
        return string.IsNullOrWhiteSpace(attachment.WorkspaceRelativePath)
            ? attachment.DisplayName
            : $"{attachment.DisplayName} ({attachment.WorkspaceRelativePath})";
    }

    private bool ShouldShowSuperpowersQuickActions(ChatMessage message)
    {
        if (!OnSubmitSuperpowersQuickInput.HasDelegate
            || (ShowSuperpowersPlanActions
                && (!OnContinueSuperpowersAction.HasDelegate
                    || !OnExecuteSuperpowersPlan.HasDelegate
                    || !OnExecuteSuperpowersSubagentPlan.HasDelegate
                    || !OnExecuteSuperpowersCompleteWorktree.HasDelegate)))
        {
            return false;
        }

        if (!string.Equals(message.Role, "assistant", StringComparison.OrdinalIgnoreCase) || message.HasError)
        {
            return false;
        }

        return !string.IsNullOrWhiteSpace(SuperpowersQuickActionMessageId)
            && string.Equals(message.Id, SuperpowersQuickActionMessageId, StringComparison.Ordinal);
    }

    private bool ShouldShowStreamingSuperpowersQuickActions()
    {
        if (!IsLoading || !OnSubmitSuperpowersQuickInput.HasDelegate)
        {
            return false;
        }

        return !ShowSuperpowersPlanActions
            || (OnContinueSuperpowersAction.HasDelegate
                && OnExecuteSuperpowersPlan.HasDelegate
                && OnExecuteSuperpowersSubagentPlan.HasDelegate
                && OnExecuteSuperpowersCompleteWorktree.HasDelegate);
    }

    private bool ShouldShowGoalQuickActions(ChatMessage message)
    {
        if (!EnableGoalQuickActions
            || !OnSubmitGoalQuickInput.HasDelegate
            || !OnGoalStatusAction.HasDelegate
            || !OnGoalPauseAction.HasDelegate
            || !OnGoalClearAction.HasDelegate
            || !OnGoalResumeAction.HasDelegate)
        {
            return false;
        }

        if (!string.Equals(message.Role, "assistant", StringComparison.OrdinalIgnoreCase) || message.HasError)
        {
            return false;
        }

        return !string.IsNullOrWhiteSpace(GoalQuickActionMessageId)
            && string.Equals(message.Id, GoalQuickActionMessageId, StringComparison.Ordinal);
    }

    private bool ShouldShowStreamingGoalQuickActions()
    {
        return EnableGoalQuickActions
               && IsLoading
               && OnSubmitGoalQuickInput.HasDelegate
               && OnGoalStatusAction.HasDelegate
               && OnGoalPauseAction.HasDelegate
               && OnGoalClearAction.HasDelegate
               && OnGoalResumeAction.HasDelegate;
    }

    private async Task HandleSuperpowersQuickInputKeyDown(ChatMessage message, KeyboardEventArgs args)
    {
        if (!string.Equals(args.Key, "Enter", StringComparison.Ordinal))
        {
            return;
        }

        await OnSubmitSuperpowersQuickInput.InvokeAsync(message);
    }

    private async Task HandleSuperpowersQuickInputChangedAsync(string? value)
    {
        SuperpowersQuickInput = value ?? string.Empty;

        if (SuperpowersQuickInputChanged.HasDelegate)
        {
            await SuperpowersQuickInputChanged.InvokeAsync(SuperpowersQuickInput);
        }
    }

    private async Task HandleGoalQuickInputKeyDown(ChatMessage message, KeyboardEventArgs args)
    {
        if (!string.Equals(args.Key, "Enter", StringComparison.Ordinal))
        {
            return;
        }

        await OnSubmitGoalQuickInput.InvokeAsync(message);
    }

    private async Task HandleGoalQuickInputChangedAsync(string? value)
    {
        GoalQuickInput = value ?? string.Empty;

        if (GoalQuickInputChanged.HasDelegate)
        {
            await GoalQuickInputChanged.InvokeAsync(GoalQuickInput);
        }
    }

    private async Task CopyMessageContent(ChatMessage message)
    {
        var content = message.Content ?? string.Empty;
        var success = await JSRuntime.InvokeAsync<bool>("clipboardCopy.copyText", content);
        
        if (success)
        {
            // Cancel any pending reset operation
            _copiedResetCts?.Cancel();
            _copiedResetCts?.Dispose();
            
            _copiedMessageId = message.Id;
            StateHasChanged();
            
            // Create new cancellation token for this operation
            _copiedResetCts = new CancellationTokenSource();
            var currentCts = _copiedResetCts;
            
            try
            {
                // Reset the copied state after 2 seconds
                await Task.Delay(2000, currentCts.Token);
                
                // Only reset if this is still the current operation
                if (_copiedResetCts == currentCts)
                {
                    _copiedMessageId = null;
                    StateHasChanged();
                }
            }
            catch (TaskCanceledException)
            {
                // Expected when a new copy operation starts
            }
        }
    }

    private void ShowFullscreenMessage(ChatMessage message)
    {
        _fullscreenMessage = message;
        StateHasChanged();
    }

    private void CloseFullscreen()
    {
        _fullscreenMessage = null;
        StateHasChanged();
    }

    private void HandleModalKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape")
        {
            CloseFullscreen();
        }
    }

    public void Dispose()
    {
        _copiedResetCts?.Cancel();
        _copiedResetCts?.Dispose();
    }
}
