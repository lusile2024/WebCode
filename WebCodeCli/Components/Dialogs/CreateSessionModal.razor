    private static string FormatFileSize(long size)
    {
        var units = new[] { "B", "KB", "MB", "GB" };
        double value = size;
        var unitIndex = 0;

        while (value >= 1024 && unitIndex < units.Length - 1)
        {
            value /= 1024;
            unitIndex++;
        }

        return unitIndex == 0 ? $"{size} B" : $"{value:0.#} {units[unitIndex]}";
    }

