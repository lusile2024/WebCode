@using System.Text.Json
@using WebCodeCli.Domain.Domain.Model
@using WebCodeCli.Domain.Domain.Service
@inject ICcSwitchService CcSwitchService
@inject ILocalizationService L

<div class="env-config-modal">
    @if (_isVisible)
    {
        <div class="fixed inset-0 bg-black/60 backdrop-blur-sm z-50 flex items-center justify-center p-4" @onclick="OnBackgroundClick">
            <div class="bg-white rounded-2xl shadow-2xl max-w-3xl w-full max-h-[90vh] flex flex-col border border-gray-300" @onclick:stopPropagation="true">
                <div class="flex items-center justify-between p-6 border-b border-gray-300 bg-gray-50 rounded-t-2xl">
                    <div class="flex items-center gap-3">
                        <svg class="w-6 h-6 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                        </svg>
                        <div>
                            <h3 class="text-lg font-bold text-gray-800">
                                @(string.IsNullOrWhiteSpace(_selectedTool?.Name)
                                    ? T("envConfig.title")
                                    : T("envConfig.titleWithTool", ("tool", _selectedTool!.Name)))
                            </h3>
                            <p class="text-sm text-gray-500">@T("envConfig.readOnlyTitle")</p>
                        </div>
                    </div>
                    <button @onclick="Close" class="text-gray-500 hover:text-gray-700 hover:bg-gray-200 rounded-lg p-2 transition-all">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                        </svg>
                    </button>
                </div>

                <div class="flex-1 overflow-y-auto p-6">
                    @if (_isLoading)
                    {
                        <div class="flex items-center justify-center py-12">
                            <div class="animate-spin h-8 w-8 border-4 border-gray-700 rounded-full border-t-transparent"></div>
                        </div>
                    }
                    else if (_toolStatus == null)
                    {
                        <div class="rounded-xl border border-red-200 bg-red-50 p-4 text-sm text-red-700">
                            @T("envConfig.loadFailed")
                        </div>
                    }
                    else if (!_toolStatus.IsManaged)
                    {
                        <div class="space-y-4">
                            <div class="rounded-xl border border-yellow-200 bg-yellow-50 p-4">
                                <p class="text-sm font-semibold text-yellow-800">@T("envConfig.unmanagedTitle")</p>
                                <p class="mt-1 text-sm text-yellow-700">@T("envConfig.unmanagedDesc")</p>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="space-y-4">
                            <div class="rounded-xl border border-blue-200 bg-blue-50 p-4">
                                <p class="text-sm font-semibold text-blue-800">@T("envConfig.readOnlyDesc")</p>
                                <p class="mt-1 text-sm text-blue-700">@T("envConfig.ccSwitchManaged")</p>
                            </div>

                            <div class="@GetStatusCardClass(_toolStatus.IsLaunchReady) rounded-xl border p-4">
                                <div class="flex items-start justify-between gap-4">
                                    <div>
                                        <p class="text-sm font-semibold">@T("envConfig.currentStatus")</p>
                                        <p class="mt-1 text-lg font-bold">
                                            @(_toolStatus.IsLaunchReady ? T("envConfig.ready") : T("envConfig.notReady"))
                                        </p>
                                    </div>
                                    <span class="@GetStatusBadgeClass(_toolStatus.IsLaunchReady) inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold">
                                        @(_toolStatus.IsLaunchReady ? T("envConfig.ready") : T("envConfig.notReady"))
                                    </span>
                                </div>
                                <p class="mt-3 text-sm">@DisplayValue(_toolStatus.StatusMessage)</p>
                            </div>

                            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                <div class="rounded-xl border border-gray-200 bg-white p-4">
                                    <p class="text-xs font-semibold uppercase tracking-wide text-gray-500">@T("envConfig.provider")</p>
                                    <p class="mt-2 text-sm font-semibold text-gray-800">@DisplayValue(_toolStatus.ActiveProviderName ?? _toolStatus.ActiveProviderId)</p>
                                    <p class="mt-1 text-xs text-gray-500">@DisplayValue(_toolStatus.ActiveProviderId)</p>
                                </div>
                                <div class="rounded-xl border border-gray-200 bg-white p-4">
                                    <p class="text-xs font-semibold uppercase tracking-wide text-gray-500">@T("envConfig.providerCategory")</p>
                                    <p class="mt-2 text-sm font-semibold text-gray-800">@DisplayValue(_toolStatus.ActiveProviderCategory)</p>
                                </div>
                                <div class="rounded-xl border border-gray-200 bg-white p-4">
                                    <p class="text-xs font-semibold uppercase tracking-wide text-gray-500">@T("envConfig.source")</p>
                                    <p class="mt-2 text-sm font-semibold text-gray-800">
                                        @(_toolStatus.UsesSettingsOverride ? T("envConfig.sourceSettings") : T("envConfig.sourceDatabase"))
                                    </p>
                                </div>
                                <div class="rounded-xl border border-gray-200 bg-white p-4">
                                    <p class="text-xs font-semibold uppercase tracking-wide text-gray-500">@T("envConfig.toolConfig")</p>
                                    <p class="mt-2 text-sm font-semibold text-gray-800">@DisplayValue(_toolStatus.ConfigDirectory)</p>
                                </div>
                            </div>

                            <div class="space-y-3">
                                @RenderPathRow(T("envConfig.liveConfigPath"), _toolStatus.LiveConfigPath, _toolStatus.HasLiveConfig)
                                @RenderPathRow(T("envConfig.settingsPath"), _toolStatus.SettingsPath, _toolStatus.HasSettingsFile)
                                @RenderPathRow(T("envConfig.databasePath"), _toolStatus.DatabasePath, _toolStatus.HasDatabase)
                            </div>
                        </div>
                    }
                </div>

                <div class="flex items-center justify-end p-6 border-t border-gray-300 bg-gray-50 rounded-b-2xl">
                    <button @onclick="Close" class="btn-primary min-w-[120px]">
                        @T("common.close")
                    </button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private bool _isVisible;
    private bool _isLoading;
    private CliToolConfig? _selectedTool;
    private CcSwitchToolStatus? _toolStatus;
    private Dictionary<string, string> _translations = new();
    private string _currentLanguage = "zh-CN";

    protected override async Task OnInitializedAsync()
    {
        await LoadTranslationsAsync();
    }

    public async Task ShowAsync(CliToolConfig tool, string? username = null)
    {
        _selectedTool = tool;
        _toolStatus = null;
        _isVisible = true;
        _isLoading = true;
        StateHasChanged();

        try
        {
            _currentLanguage = await L.GetCurrentLanguageAsync();
            await LoadTranslationsAsync();
            _toolStatus = await CcSwitchService.GetToolStatusAsync(tool.Id);
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private Task OnBackgroundClick()
    {
        Close();
        return Task.CompletedTask;
    }

    private void Close()
    {
        _isVisible = false;
        StateHasChanged();
    }

    private RenderFragment RenderPathRow(string label, string? value, bool exists) => __builder =>
    {
        <div class="rounded-xl border border-gray-200 bg-gray-50 p-4">
            <div class="flex items-center justify-between gap-3">
                <div>
                    <p class="text-xs font-semibold uppercase tracking-wide text-gray-500">@label</p>
                    <p class="mt-2 break-all text-sm text-gray-800">@DisplayValue(value)</p>
                </div>
                <span class="@GetExistsBadgeClass(exists) inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold">
                    @(exists ? T("envConfig.detected") : T("envConfig.notDetected"))
                </span>
            </div>
        </div>;
    };

    private string DisplayValue(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? T("envConfig.notAvailable") : value;
    }

    private string GetStatusCardClass(bool isReady)
    {
        return isReady
            ? "border-green-200 bg-green-50 text-green-800"
            : "border-red-200 bg-red-50 text-red-800";
    }

    private string GetStatusBadgeClass(bool isReady)
    {
        return isReady
            ? "bg-green-100 text-green-700"
            : "bg-red-100 text-red-700";
    }

    private string GetExistsBadgeClass(bool exists)
    {
        return exists
            ? "bg-green-100 text-green-700"
            : "bg-gray-200 text-gray-700";
    }

    private async Task LoadTranslationsAsync()
    {
        try
        {
            var allTranslations = await L.GetAllTranslationsAsync(_currentLanguage);
            _translations = FlattenTranslations(allTranslations);
        }
        catch
        {
            _translations = new Dictionary<string, string>();
        }
    }

    private Dictionary<string, string> FlattenTranslations(Dictionary<string, object> source, string prefix = "")
    {
        var result = new Dictionary<string, string>();

        foreach (var kvp in source)
        {
            var key = string.IsNullOrEmpty(prefix) ? kvp.Key : $"{prefix}.{kvp.Key}";

            if (kvp.Value is JsonElement jsonElement)
            {
                if (jsonElement.ValueKind == JsonValueKind.Object)
                {
                    var nested = JsonSerializer.Deserialize<Dictionary<string, object>>(jsonElement.GetRawText());
                    if (nested != null)
                    {
                        foreach (var item in FlattenTranslations(nested, key))
                        {
                            result[item.Key] = item.Value;
                        }
                    }
                }
                else if (jsonElement.ValueKind == JsonValueKind.String)
                {
                    result[key] = jsonElement.GetString() ?? key;
                }
            }
            else if (kvp.Value is Dictionary<string, object> dict)
            {
                foreach (var item in FlattenTranslations(dict, key))
                {
                    result[item.Key] = item.Value;
                }
            }
            else if (kvp.Value is string str)
            {
                result[key] = str;
            }
        }

        return result;
    }

    private string T(string key)
    {
        if (_translations.TryGetValue(key, out var value))
        {
            return value;
        }

        return key.Split('.').LastOrDefault() ?? key;
    }

    private string T(string key, params (string key, string value)[] args)
    {
        var value = T(key);
        foreach (var (argKey, argValue) in args)
        {
            value = value.Replace($"{{{argKey}}}", argValue);
        }

        return value;
    }
}
