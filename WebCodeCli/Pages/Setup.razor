@page "/setup"
@namespace WebCodeCli.Pages
@using WebCodeCli.Domain.Domain.Service
@using WebCodeCli.Components

<PageTitle>@T("setup.pageTitle")</PageTitle>

<div class="min-h-screen bg-gradient-to-br from-gray-50 via-gray-100 to-gray-200 py-4 md:py-8 px-3 md:px-4">
    <div class="max-w-4xl mx-auto">
        <div class="flex justify-end mb-4">
            <LanguageSwitcher OnLanguageChanged="HandleLanguageChanged" />
        </div>

        <div class="text-center mb-6 md:mb-8">
            <div class="inline-flex items-center justify-center mb-3 md:mb-4">
                <img src="/images/logo.png" alt="WebCode Logo" class="w-16 h-16 md:w-20 md:h-20 object-contain" />
            </div>
            <h1 class="text-2xl md:text-3xl font-bold text-gray-800 mb-2">@T("setup.title")</h1>
            <p class="text-sm md:text-base text-gray-600">@T("setup.subtitle")</p>
        </div>

        <div class="flex items-center justify-center mb-6 md:mb-8 overflow-x-auto pb-2">
            @for (var step = 1; step <= 3; step++)
            {
                <div class="flex items-center flex-shrink-0">
                    <div class="@GetStepClass(step)">
                        @if (_currentStep > step)
                        {
                            <svg class="w-4 h-4 md:w-5 md:h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                            </svg>
                        }
                        else
                        {
                            @step
                        }
                    </div>
                    <span class="ml-1.5 md:ml-2 text-xs md:text-sm font-medium @(step <= _currentStep ? "text-gray-800" : "text-gray-400") hidden sm:inline">
                        @GetStepTitle(step)
                    </span>
                    @if (step < 3)
                    {
                        <div class="w-6 md:w-12 h-0.5 mx-2 md:mx-4 @(step < _currentStep ? "bg-gray-800" : "bg-gray-300")"></div>
                    }
                </div>
            }
        </div>

        <div class="bg-white rounded-2xl shadow-2xl border border-gray-200 overflow-hidden">
            @if (_isLoading)
            {
                <div class="flex items-center justify-center py-20">
                    <div class="text-center">
                        <div class="animate-spin h-12 w-12 border-4 border-gray-700 rounded-full border-t-transparent mx-auto mb-4"></div>
                        <p class="text-gray-600">@T("setup.loading")</p>
                    </div>
                </div>
            }
            else if (_isCompleted)
            {
                <div class="p-6 md:p-12 text-center">
                    <div class="w-16 h-16 md:w-20 md:h-20 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4 md:mb-6">
                        <svg class="w-8 h-8 md:w-10 md:h-10 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                        </svg>
                    </div>
                    <h2 class="text-xl md:text-2xl font-bold text-gray-800 mb-3 md:mb-4">@T("setup.completedTitle")</h2>
                    <p class="text-sm md:text-base text-gray-600 mb-6 md:mb-8">@T("setup.completedDesc")</p>
                    <button @onclick="GoToHome" class="btn-primary px-6 md:px-8 py-2.5 md:py-3 text-base md:text-lg">
                        @T("setup.start")
                    </button>
                </div>
            }
            else
            {
                <div class="p-4 md:p-8">
                    @if (_currentStep == 1)
                    {
                        <h2 class="text-lg md:text-xl font-bold text-gray-800 mb-4 md:mb-6 flex items-center gap-2">
                            <svg class="w-5 h-5 md:w-6 md:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                            </svg>
                            @T("setup.step1Header")
                        </h2>

                        <div class="space-y-4 md:space-y-6">
                            <div class="flex items-center justify-between p-3 md:p-4 bg-gray-50 rounded-xl border border-gray-200 gap-3">
                                <div class="flex-1 min-w-0">
                                    <h3 class="font-semibold text-gray-800 text-sm md:text-base">@T("setup.enableAuthTitle")</h3>
                                    <p class="text-xs md:text-sm text-gray-600">@T("setup.enableAuthDesc")</p>
                                </div>
                                <label class="relative inline-flex items-center cursor-pointer flex-shrink-0">
                                    <input type="checkbox" @bind="_config.EnableAuth" class="sr-only peer">
                                    <div class="w-11 h-6 bg-gray-300 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-gray-300 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-gray-800"></div>
                                </label>
                            </div>

                            @if (_config.EnableAuth)
                            {
                                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                    <div>
                                        <label class="block text-sm font-medium text-gray-700 mb-2">@T("setup.adminUsernameLabel")</label>
                                        <input type="text"
                                               @bind="_config.AdminUsername"
                                               class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-gray-500 focus:border-transparent"
                                               placeholder="@T("setup.adminUsernamePlaceholder")" />
                                    </div>
                                    <div>
                                        <label class="block text-sm font-medium text-gray-700 mb-2">@T("setup.adminPasswordLabel")</label>
                                        <input type="password"
                                               @bind="_config.AdminPassword"
                                               class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-gray-500 focus:border-transparent"
                                               placeholder="@T("setup.adminPasswordPlaceholder")" />
                                    </div>
                                </div>
                            }

                            <div>
                                <label class="block text-xs md:text-sm font-medium text-gray-700 mb-2">
                                    @T("setup.workspaceRootLabel")
                                    <span class="text-gray-400 font-normal">@T("setup.workspaceRootHint")</span>
                                </label>
                                <input type="text"
                                       @bind="_config.WorkspaceRoot"
                                       class="w-full px-3 md:px-4 py-2.5 md:py-3 border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-gray-500 focus:border-transparent text-sm md:text-base"
                                       placeholder="@_defaultWorkspaceRoot" />
                                <p class="mt-2 text-xs md:text-sm text-gray-500">
                                    @T("setup.workspaceRootDesc", ("path", "/app/workspaces"))
                                </p>
                            </div>
                        </div>

                        <div class="flex justify-end mt-6 md:mt-8 pt-4 md:pt-6 border-t border-gray-200">
                            <button @onclick="NextStepAsync" class="btn-primary">
                                @T("common.next")
                                <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                                </svg>
                            </button>
                        </div>
                    }
                    else if (_currentStep == 2)
                    {
                        <h2 class="text-lg md:text-xl font-bold text-gray-800 mb-4 md:mb-6 flex items-center gap-2">
                            <svg class="w-5 h-5 md:w-6 md:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"></path>
                            </svg>
                            @T("setup.selectAssistantsHeader")
                        </h2>

                        <div class="bg-blue-50 border border-blue-200 rounded-xl p-3 md:p-4 mb-4 md:mb-6">
                            <div class="flex">
                                <svg class="w-4 h-4 md:w-5 md:h-5 text-blue-600 mt-0.5 mr-2 md:mr-3 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"></path>
                                </svg>
                                <div class="text-xs md:text-sm text-blue-800">
                                    <p class="font-bold mb-1">@T("setup.selectAssistantsTip")</p>
                                    <p>@T("setup.selectAssistantsDesc")</p>
                                </div>
                            </div>
                        </div>

                        <div class="space-y-3 md:space-y-4">
                            <div class="@GetAssistantCardClass(_enableClaudeCode) p-3 md:p-5 rounded-xl border-2 cursor-pointer transition-all hover:shadow-md"
                                 @onclick="() => _enableClaudeCode = !_enableClaudeCode">
                                <div class="flex items-center gap-3 md:gap-4">
                                    <div class="flex-shrink-0">
                                        <input type="checkbox" checked="@_enableClaudeCode"
                                               @onclick:stopPropagation="true"
                                               @onchange="() => _enableClaudeCode = !_enableClaudeCode"
                                               class="w-4 h-4 md:w-5 md:h-5 text-orange-600 border-gray-300 rounded focus:ring-orange-500 cursor-pointer" />
                                    </div>
                                    <div class="flex-shrink-0 w-10 h-10 md:w-12 md:h-12 bg-orange-100 rounded-xl flex items-center justify-center">
                                        <svg class="w-5 h-5 md:w-7 md:h-7 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                                        </svg>
                                    </div>
                                    <div class="flex-1 min-w-0">
                                        <h3 class="font-bold text-gray-800 text-base md:text-lg">Claude Code</h3>
                                        <p class="text-xs md:text-sm text-gray-600">@T("setup.claudeCodeDesc")</p>
                                    </div>
                                    @if (_enableClaudeCode)
                                    {
                                        <div class="flex-shrink-0 hidden sm:block">
                                            <span class="px-2 md:px-3 py-1 bg-orange-100 text-orange-700 text-xs font-semibold rounded-full">@T("setup.selected")</span>
                                        </div>
                                    }
                                </div>
                            </div>

                            <div class="@GetAssistantCardClass(_enableCodex) p-3 md:p-5 rounded-xl border-2 cursor-pointer transition-all hover:shadow-md"
                                 @onclick="() => _enableCodex = !_enableCodex">
                                <div class="flex items-center gap-3 md:gap-4">
                                    <div class="flex-shrink-0">
                                        <input type="checkbox" checked="@_enableCodex"
                                               @onclick:stopPropagation="true"
                                               @onchange="() => _enableCodex = !_enableCodex"
                                               class="w-4 h-4 md:w-5 md:h-5 text-green-600 border-gray-300 rounded focus:ring-green-500 cursor-pointer" />
                                    </div>
                                    <div class="flex-shrink-0 w-10 h-10 md:w-12 md:h-12 bg-green-100 rounded-xl flex items-center justify-center">
                                        <svg class="w-5 h-5 md:w-7 md:h-7 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
                                        </svg>
                                    </div>
                                    <div class="flex-1 min-w-0">
                                        <h3 class="font-bold text-gray-800 text-base md:text-lg">Codex</h3>
                                        <p class="text-xs md:text-sm text-gray-600">@T("setup.codexDesc")</p>
                                    </div>
                                    @if (_enableCodex)
                                    {
                                        <div class="flex-shrink-0 hidden sm:block">
                                            <span class="px-2 md:px-3 py-1 bg-green-100 text-green-700 text-xs font-semibold rounded-full">@T("setup.selected")</span>
                                        </div>
                                    }
                                </div>
                            </div>

                            <div class="@GetAssistantCardClass(_enableOpenCode) p-3 md:p-5 rounded-xl border-2 cursor-pointer transition-all hover:shadow-md"
                                 @onclick="() => _enableOpenCode = !_enableOpenCode">
                                <div class="flex items-center gap-3 md:gap-4">
                                    <div class="flex-shrink-0">
                                        <input type="checkbox" checked="@_enableOpenCode"
                                               @onclick:stopPropagation="true"
                                               @onchange="() => _enableOpenCode = !_enableOpenCode"
                                               class="w-4 h-4 md:w-5 md:h-5 text-purple-600 border-gray-300 rounded focus:ring-purple-500 cursor-pointer" />
                                    </div>
                                    <div class="flex-shrink-0 w-10 h-10 md:w-12 md:h-12 bg-purple-100 rounded-xl flex items-center justify-center">
                                        <svg class="w-5 h-5 md:w-7 md:h-7 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                                        </svg>
                                    </div>
                                    <div class="flex-1 min-w-0">
                                        <h3 class="font-bold text-gray-800 text-base md:text-lg">OpenCode</h3>
                                        <p class="text-xs md:text-sm text-gray-600">@T("setup.openCodeDesc")</p>
                                    </div>
                                    @if (_enableOpenCode)
                                    {
                                        <div class="flex-shrink-0 hidden sm:block">
                                            <span class="px-2 md:px-3 py-1 bg-purple-100 text-purple-700 text-xs font-semibold rounded-full">@T("setup.selected")</span>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>

                        <div class="flex flex-col sm:flex-row justify-between gap-3 mt-6 md:mt-8 pt-4 md:pt-6 border-t border-gray-200">
                            <button @onclick="PrevStep" class="btn-default order-2 sm:order-1">
                                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
                                </svg>
                                @T("common.previous")
                            </button>
                            <button @onclick="NextStepAsync" class="btn-primary order-1 sm:order-2">
                                @T("setup.continueToReview")
                                <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                                </svg>
                            </button>
                        </div>
                    }
                    else
                    {
                        <h2 class="text-lg md:text-xl font-bold text-gray-800 mb-4 md:mb-6 flex items-center gap-2">
                            <svg class="w-5 h-5 md:w-6 md:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                            </svg>
                            @T("setup.ccSwitchReviewHeader")
                        </h2>

                        <div class="space-y-4">
                            <div class="bg-blue-50 border border-blue-200 rounded-xl p-4">
                                <p class="text-sm font-semibold text-blue-800">@T("setup.ccSwitchReviewTitle")</p>
                                <p class="mt-1 text-sm text-blue-700">@T("setup.ccSwitchReviewDesc")</p>
                            </div>

                            <div class="rounded-xl border border-gray-200 bg-gray-50 p-4">
                                <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4">
                                    <div>
                                        <p class="text-sm font-semibold text-gray-800">@T("setup.ccSwitchRequirement")</p>
                                        <p class="mt-1 text-sm text-gray-600">
                                            @((_ccSwitchStatus?.IsDetected ?? false) ? T("setup.ccSwitchDetected") : T("setup.ccSwitchMissing"))
                                        </p>
                                    </div>
                                    <span class="@GetStatusBadgeClass(_ccSwitchStatus?.IsDetected ?? false) inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold">
                                        @((_ccSwitchStatus?.IsDetected ?? false) ? T("setup.detected") : T("setup.notDetected"))
                                    </span>
                                </div>

                                <div class="grid grid-cols-1 md:grid-cols-3 gap-3 mt-4">
                                    <div class="rounded-lg border border-gray-200 bg-white p-3">
                                        <p class="text-xs font-semibold uppercase tracking-wide text-gray-500">@T("setup.ccSwitchConfigDir")</p>
                                        <p class="mt-2 text-sm break-all text-gray-800">@DisplayValue(_ccSwitchStatus?.ConfigDirectory)</p>
                                    </div>
                                    <div class="rounded-lg border border-gray-200 bg-white p-3">
                                        <p class="text-xs font-semibold uppercase tracking-wide text-gray-500">@T("setup.ccSwitchDatabase")</p>
                                        <p class="mt-2 text-sm break-all text-gray-800">@DisplayValue(_ccSwitchStatus?.DatabasePath)</p>
                                    </div>
                                    <div class="rounded-lg border border-gray-200 bg-white p-3">
                                        <p class="text-xs font-semibold uppercase tracking-wide text-gray-500">@T("setup.ccSwitchSettings")</p>
                                        <p class="mt-2 text-sm break-all text-gray-800">@DisplayValue(_ccSwitchStatus?.SettingsPath)</p>
                                    </div>
                                </div>

                                @if (!string.IsNullOrWhiteSpace(_ccSwitchStatus?.ErrorMessage))
                                {
                                    <div class="mt-4 rounded-lg border border-red-200 bg-red-50 p-3 text-sm text-red-700">
                                        @_ccSwitchStatus.ErrorMessage
                                    </div>
                                }
                            </div>

                            @if (GetEnabledAssistants().Any())
                            {
                                <div class="grid grid-cols-1 gap-4">
                                    @foreach (var toolId in GetEnabledAssistants())
                                    {
                                        var status = GetToolStatus(toolId);
                                        <div class="rounded-xl border border-gray-200 bg-white p-4">
                                            <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4">
                                                <div>
                                                    <h3 class="text-base font-bold text-gray-800">@GetToolDisplayName(toolId)</h3>
                                                    <p class="mt-1 text-sm text-gray-600">@DisplayValue(status.StatusMessage)</p>
                                                </div>
                                                <span class="@GetStatusBadgeClass(status.IsLaunchReady) inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold">
                                                    @(status.IsLaunchReady ? T("setup.ready") : T("setup.notReady"))
                                                </span>
                                            </div>

                                            <div class="grid grid-cols-1 md:grid-cols-2 gap-3 mt-4">
                                                <div class="rounded-lg border border-gray-200 bg-gray-50 p-3">
                                                    <p class="text-xs font-semibold uppercase tracking-wide text-gray-500">@T("setup.provider")</p>
                                                    <p class="mt-2 text-sm text-gray-800">@DisplayValue(status.ActiveProviderName ?? status.ActiveProviderId)</p>
                                                </div>
                                                <div class="rounded-lg border border-gray-200 bg-gray-50 p-3">
                                                    <p class="text-xs font-semibold uppercase tracking-wide text-gray-500">@T("setup.providerCategory")</p>
                                                    <p class="mt-2 text-sm text-gray-800">@DisplayProviderCategory(status.ActiveProviderCategory)</p>
                                                </div>
                                                <div class="rounded-lg border border-gray-200 bg-gray-50 p-3">
                                                    <p class="text-xs font-semibold uppercase tracking-wide text-gray-500">@T("setup.source")</p>
                                                    <p class="mt-2 text-sm text-gray-800">
                                                        @(status.UsesSettingsOverride ? T("setup.ccSwitchSourceSettings") : T("setup.ccSwitchSourceDatabase"))
                                                    </p>
                                                </div>
                                                <div class="rounded-lg border border-gray-200 bg-gray-50 p-3">
                                                    <p class="text-xs font-semibold uppercase tracking-wide text-gray-500">@T("setup.liveConfigPath")</p>
                                                    <p class="mt-2 text-sm break-all text-gray-800">@DisplayValue(status.LiveConfigPath)</p>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="rounded-xl border border-gray-200 bg-gray-50 p-4">
                                    <p class="text-sm font-semibold text-gray-800">@T("setup.noAssistantsSelected")</p>
                                    <p class="mt-1 text-sm text-gray-600">@T("setup.noAssistantsSelectedDesc")</p>
                                </div>
                            }
                        </div>

                        <div class="flex flex-col sm:flex-row justify-between gap-3 mt-6 md:mt-8 pt-4 md:pt-6 border-t border-gray-200">
                            <button @onclick="PrevStep" class="btn-default order-3 sm:order-1">
                                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
                                </svg>
                                @T("common.previous")
                            </button>
                            <button @onclick="RefreshCcSwitchStatusAsync" class="btn-default order-2">
                                @T("setup.refreshStatus")
                            </button>
                            <button @onclick="CompleteSetup" class="btn-primary order-1 sm:order-3">
                                @T("setup.completeSetup")
                                <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                                </svg>
                            </button>
                        </div>
                    }
                </div>
            }
        </div>

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="mt-6 bg-red-50 border-l-4 border-red-500 text-red-700 px-4 py-3 rounded-lg">
                <div class="flex items-start gap-2">
                    <svg class="w-5 h-5 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                    <span>@_errorMessage</span>
                </div>
            </div>
        }

        <div class="mt-8 text-center text-sm text-gray-500">
            <p>@T("setup.footer", ("year", DateTime.Now.Year.ToString()))</p>
        </div>
    </div>
</div>
